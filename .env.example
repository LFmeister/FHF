SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
FHF_IOT_CONTROL_TOKEN=replace-with-a-long-random-secret
FHF_IOT_TELEMETRY_INTERVAL_SEC=30
FHF_IOT_COMMAND_POLL_SEC=5
FHF_IOT_COMMAND_RETRY_SEC=60

TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
GREENHOUSE_DEVICE_ID=replace-with-your-device-id
GREENHOUSE_BOT_COMMAND_TOKEN=replace-with-a-long-random-secret
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
TELEMETRY_STALE_MINUTES=30
MAX_IRRIGATION_SECONDS=120

# Voz local del bot de Telegram.
# Ejecuta agents/install_piper_spanish_female_voice.sh para instalar Piper y el modelo.
GREENHOUSE_BOT_VOICE_ENABLED=true
GREENHOUSE_BOT_VOICE_ENGINE=piper
GREENHOUSE_BOT_VOICE_MAX_CHARS=900
GREENHOUSE_BOT_VOICE_STATE_FILE=/home/meister/projects/FHF/agents/.greenhouse_bot_voice.json
PIPER_VOICE_NAME=sofia
PIPER_BIN=/home/meister/projects/FHF/agents/.venv-piper/bin/piper
PIPER_VOICE_MODEL=/home/meister/piper-voices/es_ES-mls_9972-low.onnx
FFMPEG_BIN=ffmpeg
